{
  "name": "@onlynative/components",
  "version": "0.0.0",
  "private": false,
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./typography": {
      "types": "./dist/typography/index.d.ts",
      "react-native": "./src/typography/index.ts",
      "default": "./dist/typography/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "typography": ["dist/typography/index.d.ts"]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/typography/index.ts --dts --format cjs --outDir dist --clean",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "peerDependencies": {
    "@expo/vector-icons": ">=15.0.0",
    "@onlynative/core": "0.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": ">=5.0.0"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.81.5",
    "@onlynative/core": "workspace:*",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
