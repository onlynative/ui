{
  "name": "@onlynative/core",
  "version": "0.1.0-alpha.0",
  "description": "Material Design 3 theme system for React Native — colors, typography, shape, spacing, and motion tokens.",
  "private": false,
  "sideEffects": false,
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/onlynative/ui.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/onlynative/ui",
  "keywords": [
    "react-native",
    "material-design-3",
    "theme",
    "ui",
    "md3"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --outDir dist --clean",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.81.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
