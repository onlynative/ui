{
  "name": "@onlynative/utils",
  "version": "0.1.0-alpha.3",
  "description": "Shared utilities for OnlyNative — color helpers, elevation styles, RTL support, and more.",
  "private": true,
  "sideEffects": false,
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "react-native": "./src/index.ts",
      "browser": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./test": {
      "types": "./dist/test-utils/index.d.mts",
      "react-native": "./src/test-utils/index.ts",
      "browser": "./src/test-utils/index.ts",
      "import": "./dist/test-utils/index.mjs",
      "default": "./dist/test-utils/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "test": [
        "dist/test-utils/index.d.mts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/onlynative/ui.git",
    "directory": "packages/utils"
  },
  "homepage": "https://github.com/onlynative/ui",
  "keywords": [
    "react-native",
    "material-design-3",
    "utils",
    "md3"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/test-utils/index.ts --dts --format esm --outDir dist --clean --external @expo/vector-icons",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "peerDependencies": {
    "@onlynative/core": ">=0.1.0-alpha.3",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@onlynative/core": "workspace:*",
    "@react-native/babel-preset": "^0.81.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
